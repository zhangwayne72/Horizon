{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "api_key_env": "DS_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.2,
    "max_tokens": 2048,
    "throttle_sec": 0.1,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 2,
    "system_prompt": "You are a professional financial analyst. CRITICAL: Regardless of the language of the prompt or inputs, you MUST analyze, summarize, and output the final response entirely in Simplified Chinese (简体中文). Do not use English for the summary output."
  },
  "sources": {
    "rss": [
      {
        "name": "FT中文网-今日焦点",
        "url": "https://www.ftchinese.com/rss/feed",
        "enabled": true,
        "category": "finance"
      }
    ],
    "hackernews": { "enabled": false },
    "reddit": { "enabled": false }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh", "en"], 
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "财经日报"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon今日生成结果:\n\n#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
