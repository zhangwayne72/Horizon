{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "api_key_env": "DS_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.2,
    "max_tokens": 2048,
    "throttle_sec": 0.1,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 2
  },
  "sources": {
    "rss": [
      {
        "name": "新华网-财经",
        "url": "http://www.news.cn/fortune/rss.xml",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "国际金融报",
        "url": "http://www.ifnews.com/rss.php",
        "enabled": true,
        "category": "finance"
      }
    ],
    "hackernews": { "enabled": false },
    "reddit": { "enabled": false }
  },
  "filtering": {
    "ai_score_threshold": 1.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh", "en"], 
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "Horizon 财经日报 (请使用中文输出)"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "请注意：如果以下摘要为英文，请自动在心中或由模型转换为中文阅读。\n\n#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
