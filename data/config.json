{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-1.5-flash",
    "api_key_env": "GEMINI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "rss": [
      {
        "name": "财联社电报",
        "url": "https://feeds.crabpi.com/cls-telegraph",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "新浪财经-滚动新闻",
        "url": "https://feedx.net/rss/sinafinance.xml",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "网易财经-股票要闻",
        "url": "https://money.163.com/special/00252G15/money_rss.xml",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "华尔街见闻-快讯",
        "url": "https://feedx.net/rss/wallstreetcn.xml",
        "enabled": true,
        "category": "finance"
      }
    ]
  },
  "filtering": {
    "ai_score_threshold": 2.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh", "en"],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
