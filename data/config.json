{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "api_key_env": "DS_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.2,
    "max_tokens": 2048,
    "throttle_sec": 0.1,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 2,
    "system_prompt": "你是一位专业的中文财经分析师。请注意：无论输入源是什么语言，你必须完全使用【简体中文】进行分析、总结和输出。绝对不允许出现英文摘要或英文回复。所有输出结构必须符合中文阅读习惯。"
  },
  "sources": {
    "rss": [
      {
        "name": "财联社 - 电报",
        "url": "https://rss.08182005.xyz/cls/telegraph/2",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "第一财经 - 快讯",
        "url": "https://rss.08182005.xyz/yicai/brief",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "华尔街见闻 - 全球快讯",
        "url": "https://rss.08182005.xyz/wallstreetcn/news/global",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "新浪财经 - 7x24快讯",
        "url": "https://rss.08182005.xyz/sina/finance/7x24",
        "enabled": false,
        "category": "finance"
      }
    ],
    "hackernews": {
      "enabled": false
    },
    "reddit": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "财经日报"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "今日生成结果:\n\n#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
