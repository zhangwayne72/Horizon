{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GEMINI_API_KEY",
    "temperature": 0.2,
    "max_tokens": 2048,
    "throttle_sec": 0.1,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "rss": [
      {
        "name": "财联社 - 电报",
        "url": "https://rss.08182005.xyz/cls/telegraph/2",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "第一财经 - 快讯",
        "url": "https://rss.08182005.xyz/yicai/brief",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "东方财富 - 财经快讯",
        "url": "https://rss.08182005.xyz/eastmoney/report/1",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "巨潮资讯网 - 当日公告",
        "url": "https://rss.08182005.xyz/cninfo/announcement",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "新浪财经 - 7x24快讯",
        "url": "https://rss.08182005.xyz/sina/finance/7x24",
        "enabled": false,
        "category": "finance"
      }
    ],
    "hackernews": {
      "enabled": false
    },
    "reddit": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "财经&公告日报"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "今日生成结果:\n\n#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
